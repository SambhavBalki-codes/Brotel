<%- include("../partials/head", {pageTitle: "Home Added", isLoggedIn}) %>
</head>

  <%- include("../partials/header",{user : user}) %>

  <% if(isLoggedIn) { %>
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="bg-white p-8 rounded-2xl shadow-card border border-surface-200 w-96 text-center">

      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-accent-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-accent-600" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
      </div>

      <span class="inline-block mb-2 px-3 py-1 rounded-full bg-primary-50 text-primary-700 text-xs font-semibold uppercase tracking-wide">
        Listing Unlocked
      </span>

      <h1 class="text-2xl font-bold text-gray-900 mb-1">Your home has been added successfully!</h1>
      <p class="text-sm text-gray-500 mb-6">It's now live and ready to be discovered by guests.</p>

      <a href="/store" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-lg shadow-card hover:bg-primary-700 hover:shadow-card-hover hover:scale-105 active:scale-95 transition-all duration-200">
        Go Back to Home
      </a>
    </div>
  </main>
  <% }%>

</body>
</html>