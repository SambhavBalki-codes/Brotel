<%- include("../partials/head", {pageTitle: "Host Home List", isLoggedIn}) %>
</head>

  <%- include("../partials/header",{user : user}) %>

  <% if(isLoggedIn) { %>
  <main class="min-h-screen py-10">
    
    <div class="max-w-7xl w-full mx-auto px-6">

      <!-- Heading -->
      <div class="text-center mb-10">
        <span class="inline-block mb-3 px-3 py-1 rounded-full bg-primary-50 text-primary-700 text-xs font-semibold uppercase tracking-wide">
          Host Dashboard
        </span>
        <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
          Your Hosted Homes
        </h1>

        <p class="text-gray-500 mt-2 text-lg">
          Manage the properties you've listed
        </p>
      </div>

      <% if (!registeredHomes || registeredHomes.length === 0) { %>

        <!-- Empty State -->
        <div class="bg-white rounded-2xl shadow-card p-8 text-center border border-surface-200">
          <div class="text-5xl mb-4">🏠</div>

          <h2 class="text-2xl font-bold text-gray-800 mb-2">
            No Homes Hosted Yet
          </h2>
        </div>

      <% } else { %>

        <!-- Home Cards -->
        <ul class="grid gap-5 md:grid-cols-2">

          <% registeredHomes.forEach(home => { %>

            <li class="bg-white border border-surface-200 rounded-2xl shadow-card hover:shadow-card-hover hover:border-primary-200 transition-all duration-300">

              <div class="p-6">

                <!-- Top: Image left, details center, price right -->
                <div class="flex flex-col sm:flex-row sm:items-start gap-4">

                  <!-- Photo (left) -->
                  <div class="flex-shrink-0">
                    <div class="flex flex-wrap gap-3">
                      <% const photoList = Array.isArray(home.photo) ? home.photo : home.photo ? [home.photo] : []; %>
                      <% photoList.forEach(photo => { %>
                        <img
                          src="/<%= photo %>"
                          alt="<%= home.houseName %>"
                          class="w-48 h-48 sm:w-52 sm:h-52 object-cover rounded-3xl border border-surface-200 shadow-sm"
                        />
                      <% }) %>
                    </div>
                  </div>

                  <!-- Details (center) -->
                  <div class="flex-1">
                    <h2 class="text-2xl font-bold text-gray-800 tracking-tight">
                      <%= home.houseName %>
                    </h2>

                    <div class="mt-3 flex items-center text-gray-500 text-sm">
                      <span class="mr-2 text-base">📍</span>
                      <span class="font-medium">
                        <%= home.location %>
                      </span>
                    </div>

                    <div class="mt-3 text-gray-600 text-sm">
                      <%= home.description ? (home.description.length > 140 ? home.description.substring(0,140) + '...' : home.description) : 'No description provided.' %>
                    </div>
                  </div>

                  <!-- Price (right) -->
                  <div class="mt-2 sm:mt-0 flex-shrink-0 bg-primary-50 text-primary-700 px-4 py-2 rounded-xl text-sm font-bold border border-primary-100">
                    $<%= home.pricePerNight %>
                    <span class="text-xs font-medium text-gray-500"> / Night</span>
                  </div>

                </div>

                <!-- Divider -->
                <div class="border-t border-surface-100 my-5"></div>

                <!-- Bottom -->
                <div class="flex justify-end gap-3">

                  <!-- Edit Button -->
                  <a 
                    href="/host/editHome/<%= home._id.toString() %>?editing=true" 
                    class="bg-accent-400 hover:bg-accent-500 text-gray-900 px-5 py-2.5 rounded-xl font-semibold tracking-wide shadow-card hover:shadow-card-hover hover:scale-105 active:scale-95 transition-all duration-200"
                  >
                    Edit
                  </a>
                  
                  <form action="/host/deletehome/<%= home._id.toString() %>" method="post">
                    <button type="submit" class="bg-white border border-red-200 hover:bg-red-50 text-red-600 px-5 py-2.5 rounded-xl font-semibold tracking-wide shadow-card hover:shadow-card-hover transition-all duration-200">Delete Home</button>
                  </form>

                </div>

              </div>

            </li>

          <% }) %>

        </ul>

      <% } %>

    </div>

  </main>

  <% }%>

</body>
</html>