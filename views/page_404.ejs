<%- include("partials/head", {pageTitle: "404 - Page Not Found" ,isLoggedIn}) %>
</head>

  <%- include("partials/header" , {user : user}) %>

  
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="bg-white p-10 rounded-2xl shadow-card border border-surface-200 w-96 text-center">

      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface-100 flex items-center justify-center">
        <span class="text-2xl font-extrabold text-primary-600">?</span>
      </div>

      <span class="inline-block mb-2 px-3 py-1 rounded-full bg-surface-100 text-gray-500 text-xs font-semibold uppercase tracking-wide">
        Error 404
      </span>

      <h1 class="text-2xl font-bold text-gray-900">Page Not Found</h1>
      <p class="text-sm text-gray-500 mt-2">The page you're looking for doesn't exist or has moved.</p>

      <a href="/store" class="mt-6 inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white font-semibold rounded-lg shadow-card hover:bg-primary-700 hover:shadow-card-hover hover:scale-105 active:scale-95 transition-all duration-200">
        Back to Home
      </a>

    </div>

  </main>
  

</body>
</html>