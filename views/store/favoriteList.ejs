<%- include("../partials/head", { pageTitle: "Favorite Homes", isLoggedIn }) %>

</head>

<%- include("../partials/header",{user : user}) %>
<% if(isLoggedIn) { %>
  <main class="min-h-screen py-10 px-4">

    <div class="max-w-7xl mx-auto px-6">

      <!-- Heading -->
      <div class="text-center mb-10">

        <span class="inline-block mb-3 px-3 py-1 rounded-full bg-accent-100 text-accent-700 text-xs font-semibold uppercase tracking-wide">
          Saved Collection
        </span>

        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
          Favorite Homes
        </h1>

        <p class="text-gray-500">
          Browse all your saved homes in one place.
        </p>

      </div>

      <% if (!registeredHomes || registeredHomes.length === 0) { %>

        <!-- Empty State -->
        <div class="bg-white rounded-3xl shadow-card p-12 text-center border border-surface-200">

          <div class="text-7xl mb-5">
            🏠
          </div>

          <h2 class="text-3xl font-bold text-gray-800 mb-3">
            No Favorite Homes Yet
          </h2>

          <p class="text-gray-500">
            Start exploring and add homes to your favorites list.
          </p>

        </div>

      <% } else { %>

        <!-- Home Cards -->
        <div class="grid gap-6 md:grid-cols-2">

          <% registeredHomes.filter(Boolean).forEach(home => { %>

            <div class="bg-white rounded-3xl border border-surface-200 shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300">

              <div class="p-7">

                <div class="flex flex-col sm:flex-row sm:items-start gap-4">

                  <!-- Photo (left) -->
                  <div class="flex-shrink-0">
                    <div class="flex flex-wrap gap-3">
                      <% const photoList = Array.isArray(home.photo) ? home.photo : home.photo ? [home.photo] : []; %>
                      <% photoList.forEach(photo => { %>
                        <img
                          src="/<%= photo %>"
                          alt="<%= home.houseName %>"
                          class="w-48 h-48 sm:w-52 sm:h-52 object-cover rounded-3xl border border-surface-200 shadow-sm"
                        />
                      <% }) %>
                    </div>
                  </div>

                  <!-- Home Info -->
                  <div class="flex-1">

                    <div class="flex items-center gap-2 mb-1">
                      <span class="text-accent-500">❤️</span>
                      <h2 class="text-2xl md:text-3xl font-bold text-gray-800">
                        <%= home.houseName %>
                      </h2>
                    </div>

                    <div class="flex items-center mt-3 text-gray-500">

                      <span class="mr-2 text-lg">📍</span>

                      <span class="font-medium">
                        <%= home.location %>
                      </span>

                    </div>

                    <div class="mt-3 text-gray-600 text-sm">
                      <%= home.description ? (home.description.length > 140 ? home.description.substring(0,140) + '...' : home.description) : 'No description provided.' %>
                    </div>

                  </div>

                  <!-- Price -->
                  <div class="mt-2 sm:mt-0 flex-shrink-0 bg-primary-50 border border-primary-100 text-primary-700 px-5 py-3 rounded-2xl text-center">
                    <div class="text-2xl font-bold">$<%= home.pricePerNight %></div>
                    <div class="text-xs text-gray-500">per night</div>
                  </div>

                </div>

                <div class="border-t border-surface-100 my-6"></div>

                <!-- Buttons -->
                <div class="flex justify-end gap-3">

                  <a
                    href="/store/homeDetail/<%= home._id.toString() %>"
                    class="bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-xl font-semibold shadow-card hover:shadow-card-hover hover:scale-105 active:scale-95 transition-all duration-300"
                  >
                    View Details
                  </a>

                </div>

              </div>

            </div>

          <% }) %>

        </div>

      <% } %>

    </div>

  </main>
  <% }%>

</body>

</html>