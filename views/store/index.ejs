<%- include("../partials/head", {pageTitle: "Home", isLoggedIn}) %>
</head>

<%- include("../partials/header",{user : user}) %>

<% if (!isLoggedIn) { %>
  <main class="relative min-h-screen overflow-hidden bg-transparent py-8 sm:py-10">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-[-8%] top-[-5%] h-48 w-48 rounded-full bg-primary-200/40 blur-3xl"></div>
      <div class="absolute right-[-6%] top-[10%] h-60 w-60 rounded-full bg-accent-200/35 blur-3xl"></div>
      <div class="absolute bottom-[-5%] left-[20%] h-56 w-56 rounded-full bg-primary-100/50 blur-3xl"></div>
    </div>

    <div class="relative mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
      <section class="overflow-hidden rounded-[2rem] border border-white/70 bg-white/70 p-6 shadow-[0_25px_80px_rgba(15,23,42,0.08)] backdrop-blur-xl sm:p-8 lg:p-10">
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 rounded-full border border-primary-100 bg-primary-50/80 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.25em] text-primary-700 shadow-sm">
              <span class="h-2.5 w-2.5 rounded-full bg-primary-500"></span>
              Welcome Guest
            </div>

            <div class="space-y-4">
              <h1 class="max-w-2xl text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
                Discover stays that feel as good as they look.
              </h1>
              <p class="max-w-xl text-lg leading-8 text-gray-600">
                Browse inspiring homes, save your favorites, and sign in when you're ready to turn a great trip into a memorable one.
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
              <a href="/auth/login" class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-primary-600 to-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-200/70 transition duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-primary-200/80">
                Login
                <span class="text-base">→</span>
              </a>
              <div class="rounded-full border border-surface-200 bg-white/80 px-4 py-2 text-sm font-medium text-gray-600 shadow-sm">
                No clutter. Just comfort.
              </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
              <div class="-rotate-3 rounded-2xl border border-primary-100 bg-gradient-to-br from-primary-50 to-white px-4 py-3 text-sm font-semibold text-primary-700 shadow-sm transition duration-300 hover:-translate-y-1">
                🌙 Sleep here. Regret later.
              </div>
              <div class="rotate-2 rounded-2xl border border-accent-100 bg-gradient-to-br from-accent-50 to-white px-4 py-3 text-sm font-semibold text-accent-700 shadow-sm transition duration-300 hover:-translate-y-1">
                🧼 Probably cleaner than your ex's apartment.
              </div>
              <div class="-rotate-1 rounded-2xl border border-surface-200 bg-white/90 px-4 py-3 text-sm font-semibold text-gray-700 shadow-sm transition duration-300 hover:-translate-y-1">
                📶 The WiFi is faster than your situationship.
              </div>
              <div class="rotate-3 rounded-2xl border border-primary-100 bg-white/90 px-4 py-3 text-sm font-semibold text-primary-700 shadow-sm transition duration-300 hover:-translate-y-1">
                🧳 Your bugs deserve a vacation too.
              </div>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            <div class="group overflow-hidden rounded-[1.5rem] border border-white/70 bg-white/80 shadow-[0_18px_50px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_70px_rgba(15,23,42,0.12)]">
              <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1200&q=80" alt="Bright modern hotel room" class="h-56 w-full object-cover transition duration-500 group-hover:scale-105" />
              <div class="space-y-2 p-5">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg font-semibold text-gray-900">Modern retreat</h3>
                  <span class="rounded-full bg-primary-50 px-2.5 py-1 text-xs font-semibold text-primary-700">⭐ 4.9</span>
                </div>
                <p class="text-sm text-gray-500">Soft lighting, calm spaces, and thoughtful comfort for every stay.</p>
                <div class="flex items-center justify-between pt-2 text-sm text-gray-600">
                  <span>Goa, India</span>
                  <span class="font-semibold text-gray-900">$120/night</span>
                </div>
              </div>
            </div>

            <div class="group overflow-hidden rounded-[1.5rem] border border-white/70 bg-white/80 shadow-[0_18px_50px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_70px_rgba(15,23,42,0.12)]">
              <img src="https://images.unsplash.com/photo-1494526585095-c41746248156?auto=format&fit=crop&w=1200&q=80" alt="Luxury hotel interior with warm decor" class="h-56 w-full object-cover transition duration-500 group-hover:scale-105" />
              <div class="space-y-2 p-5">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg font-semibold text-gray-900">Elegant getaway</h3>
                  <span class="rounded-full bg-primary-50 px-2.5 py-1 text-xs font-semibold text-primary-700">⭐ 4.9</span>
                </div>
                <p class="text-sm text-gray-500">Warm interiors and refined details that make every visit memorable.</p>
                <div class="flex items-center justify-between pt-2 text-sm text-gray-600">
                  <span>Bali, Indonesia</span>
                  <span class="font-semibold text-gray-900">$180/night</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

    
    </div>
  </main>
<% } %>

</body>
</html>